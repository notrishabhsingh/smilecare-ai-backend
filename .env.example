# ─── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Firebase / Firestore ───────────────────────────────────
# Base64-encoded Firebase Admin service account JSON.
# If unset, the server runs with in-memory storage (no persistence).
FIREBASE_SERVICE_ACCOUNT_B64=

# ─── Google Calendar ────────────────────────────────────────
# Base64-encoded Google service account JSON with Calendar API enabled.
# If unset, calendar events are skipped (booking still completes).
GOOGLE_SERVICE_ACCOUNT_B64=
# The calendar ID to create events in. "primary" is the account's main calendar.
GOOGLE_CALENDAR_ID=primary

# ─── Twilio (SMS) ────────────────────────────────────────────
# All four must be set for SMS to send. If any are unset, SMS is skipped.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# ─── Booking Metadata ───────────────────────────────────────
# Stored in the booking record. Does not affect which number SMS is sent to.
PATIENT_PHONE=+919876543210

# ─── How to base64-encode a service account JSON file ───────
# PowerShell:
#   [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes((Get-Content ./service-account.json -Raw)))
# macOS / Linux:
#   base64 -i service-account.json | pbcopy   (copies to clipboard)
#   cat service-account.json | base64          (prints to terminal)
